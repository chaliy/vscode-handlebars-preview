{
  "name": "handlebars-preview",
  "displayName": "Handlebars Preview",
  "description": "Live preview for Handlebar templates",
  "version": "2.0.0",
  "publisher": "chaliy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaliy/vscode-handlebars-preview"
  },
  "galleryBanner": {
    "color": "#0F6378",
    "theme": "dark"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Handlebars",
    "Live Preview"
  ],
  "activationEvents": [
    "onCommand:handlebars.preview",
    "onCommand:handlebars.loadPartials",
    "onCommand:handlebars.enableUnsafeHelpers",
    "onWebviewPanel:handlebars"
  ],
  "main": "./out/extension.js",
  "browser": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "contributes": {
    "languages": [
      {
        "id": "handlebars",
        "aliases": [
          "Handlebars",
          "handlebars"
        ],
        "extensions": [
          ".handlebars",
          ".hbs"
        ]
      }
    ],
    "commands": [
      {
        "command": "handlebars.preview",
        "title": "Handlebars: Open Preview"
      },
      {
        "command": "handlebars.loadPartials",
        "title": "Handlebars: Load Partials"
      },
      {
        "command": "handlebars.enableUnsafeHelpers",
        "title": "Handlebars: Enable Unsafe Helpers"
      }
    ],
    "keybindings": [
      {
        "command": "handlebars.preview",
        "key": "ctrl+k h",
        "when": "!terminalFocus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "handlebars.preview",
          "when": "resourceLangId == handlebars",
          "group": "Handlebars"
        }
      ],
      "editor/title/context": [
        {
          "command": "handlebars.preview",
          "when": "resourceLangId == handlebars",
          "group": "Handlebars"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Handlebars Preview",
      "properties": {
        "handlebars.partials": {
          "type": "array",
          "description": "List of partial file URIs to load by basename for preview rendering.",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "handlebarsPreview.dataFileSuffix": {
          "type": "string",
          "default": ".json",
          "description": "Suffix appended to the template file name to find preview data."
        },
        "handlebarsPreview.backgroundColor": {
          "type": "string",
          "default": "",
          "description": "CSS color value used for the preview webview background. Leave empty to use the default VS Code webview background."
        },
        "handlebarsPreview.unsafeHelpers.enabled": {
          "type": "boolean",
          "default": false,
          "restricted": true,
          "description": "Enable loading custom Handlebars helpers from workspace JavaScript. This executes workspace code in trusted desktop workspaces only."
        },
        "handlebarsPreview.unsafeHelpers.file": {
          "type": "string",
          "default": "",
          "restricted": true,
          "description": "Optional helper module path or URI. Relative paths resolve from the workspace folder; leave empty to use the adjacent file convention, such as email.handlebars.js."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package:bundle",
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && tsc -p ./ && node esbuild.js",
    "compile:web-test": "node esbuild.js --web-tests",
    "package:bundle": "npm run check-types && tsc -p ./ && node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:web": "npm run compile && npm run compile:web-test && vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=out/web/test/extensionTests.js .",
    "publish": "vsce publish",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/test-web": "^0.0.81",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.11",
    "eslint": "^10.6.0",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "handlebars": "^4.7.7"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.7"
  }
}
