{
  "name": "handlebars-preview",
  "displayName": "Handlebars Preview",
  "description": "Live preview for Handlebar templates",
  "version": "2.0.0",
  "publisher": "chaliy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.125.0"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaliy/vscode-handlebars-preview"
  },
  "galleryBanner": {
    "color": "#0F6378",
    "theme": "dark"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Handlebars",
    "Live Preview"
  ],
  "activationEvents": [
    "onCommand:handlebars.preview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "handlebars.preview",
        "title": "Handlebars: Open Preview"
      }
    ],
    "keybindings": [
      {
        "command": "handlebars.preview",
        "key": "ctrl+k h",
        "when": "!terminalFocus"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "handlebars.preview",
          "when": "resourceLangId == handlebars",
          "group": "Handlebars"
        }
      ],
      "editor/title/context": [
        {
          "command": "handlebars.preview",
          "when": "resourceLangId == handlebars",
          "group": "Handlebars"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production --devtool hidden-source-map",
    "watch": "webpack --mode development --watch",
    "pretest": "tsc -p ./ && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js",
    "publish": "vsce publish",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "mocha": "^11.7.6",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "dependencies": {
    "handlebars": "^4.7.7"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.7"
  }
}
